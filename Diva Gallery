<!index.html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diva Gallery - Where Nature Meets Luxury</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --gold: #d4af37;
            --deep-black: #0a0a0a;
            --rich-purple: #6b4c9a;
            --white: #ffffff;
            --cream: #f5f3f0;
            --accent: #8b5fbf;
        }

        body {
            font-family: 'Georgia', serif;
            background: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            padding: 1rem 2rem;
        }

        nav .container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--gold);
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .nav-menu {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-menu a {
            color: var(--white);
            text-decoration: none;
            transition: color 0.3s ease;
            position: relative;
            font-size: 0.95rem;
        }

        .nav-menu a:hover {
            color: var(--gold);
        }

        .nav-menu a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--gold);
            transition: width 0.3s ease;
        }

        .nav-menu a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            margin-top: 80px;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(ellipse at center, rgba(107, 76, 154, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-content {
            text-align: center;
            z-index: 10;
            animation: fadeInUp 1s ease;
        }

        .hero-tagline {
            font-size: 1.1rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
            animation: fadeInDown 1s ease;
        }

        .hero-title {
            font-size: 4.5rem;
            font-weight: bold;
            margin: 1rem 0;
            color: var(--white);
            line-height: 1.1;
            animation: fadeInUp 1.2s ease;
            text-shadow: 0 10px 40px rgba(212, 175, 55, 0.3);
        }

        .hero-subtitle {
            font-size: 1.5rem;
            color: var(--cream);
            margin: 2rem 0;
            font-style: italic;
            animation: fadeInUp 1.4s ease;
        }

        .cta-buttons {
            display: flex;
            gap: 2rem;
            justify-content: center;
            margin-top: 3rem;
            animation: fadeInUp 1.6s ease;
        }

        .btn {
            padding: 1rem 2.5rem;
            font-size: 1rem;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-radius: 50px;
            font-family: 'Georgia', serif;
            font-weight: bold;
        }

        .btn-primary {
            background: var(--gold);
            color: var(--deep-black);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: var(--gold);
            border: 2px solid var(--gold);
        }

        .btn-secondary:hover {
            background: var(--gold);
            color: var(--deep-black);
            transform: translateY(-3px);
        }

        /* Main Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Sections */
        .section {
            padding: 5rem 0;
            position: relative;
        }

        .section-title {
            font-size: 3.5rem;
            text-align: center;
            margin-bottom: 3rem;
            color: var(--gold);
            position: relative;
            display: inline-block;
            width: 100%;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
        }

        /* Buyer Section */
        #buyer {
            background: linear-gradient(135deg, rgba(10, 10, 10, 0.8) 0%, rgba(107, 76, 154, 0.05) 100%);
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .gallery-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .gallery-item:hover {
            transform: translateY(-10px);
            border-color: var(--gold);
            box-shadow: 0 20px 60px rgba(212, 175, 55, 0.2);
        }

        .item-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, var(--rich-purple), var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            transition: all 0.3s ease;
        }

        .gallery-item:hover .item-image {
            background: linear-gradient(135deg, var(--accent), var(--rich-purple));
        }

        .item-content {
            padding: 2rem;
        }

        .item-title {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            color: var(--gold);
        }

        .item-price {
            font-size: 1.1rem;
            color: var(--cream);
            margin-bottom: 1rem;
        }

        .item-description {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* Owner Section */
        #owner {
            background: linear-gradient(135deg, rgba(107, 76, 154, 0.1) 0%, rgba(10, 10, 10, 0.8) 100%);
        }

        .owner-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            margin-top: 3rem;
        }

        .owner-info h3 {
            font-size: 1.5rem;
            color: var(--gold);
            margin-bottom: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .owner-info p {
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.8;
            margin-bottom: 1.5rem;
            font-size: 1rem;
        }

        .contact-info {
            background: rgba(212, 175, 55, 0.05);
            border-left: 3px solid var(--gold);
            padding: 2rem;
            margin-top: 2rem;
            border-radius: 5px;
        }

        .contact-item {
            margin-bottom: 1rem;
            color: var(--cream);
        }

        .contact-item strong {
            color: var(--gold);
            display: block;
            margin-bottom: 0.3rem;
        }

        /* Image Upload Section */
        .upload-section {
            background: rgba(107, 76, 154, 0.1);
            border: 2px dashed var(--gold);
            border-radius: 10px;
            padding: 2rem;
            text-align: center;
            margin-bottom: 2rem;
            transition: all 0.3s ease;
        }

        .upload-section:hover {
            background: rgba(107, 76, 154, 0.2);
            border-color: var(--accent);
        }

        .upload-section h4 {
            color: var(--gold);
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input[type="file"],
        input[type="text"],
        textarea {
            width: 100%;
            padding: 0.75rem;
            margin-bottom: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            color: var(--white);
            border-radius: 5px;
            font-family: 'Georgia', serif;
        }

        input[type="text"]::placeholder,
        textarea::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .upload-form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        /* Footer */
        footer {
            background: rgba(10, 10, 10, 0.95);
            border-top: 1px solid rgba(212, 175, 55, 0.2);
            padding: 3rem 0;
            text-align: center;
            color: rgba(255, 255, 255, 0.6);
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--gold);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--accent);
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }

            .nav-menu {
                gap: 1rem;
                font-size: 0.85rem;
            }

            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }

            .owner-container {
                grid-template-columns: 1fr;
            }

            .upload-form {
                grid-template-columns: 1fr;
            }

            .section-title {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container" style="width: 100%; max-width: 100%; padding: 0 2rem;">
            <div class="nav-logo">✦ DIVA</div>
            <ul class="nav-menu">
                <li><a href="#buyer">Collections</a></li>
                <li><a href="#owner">Owner Portal</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <p class="hero-tagline">Luxury Geodes & Crystals</p>
            <h1 class="hero-title">DIVA GALLERY</h1>
            <p class="hero-subtitle">Where Nature Meets Luxury</p>
            <div class="cta-buttons">
                <button class="btn btn-primary" onclick="scrollTo('buyer'); return false;">Shop Now</button>
                <button class="btn btn-secondary" onclick="scrollTo('owner'); return false;">Owner Portal</button>
            </div>
        </div>
    </section>

    <!-- Buyer Section -->
    <section id="buyer" class="section">
        <div class="container">
            <h2 class="section-title">Our Collections</h2>
            <div class="gallery-grid" id="gallery">
                <div class="gallery-item">
