                    </div>
                </div>
                <div class="gallery-item">
                    <div class="item-image">✨</div>
                    <div class="item-content">
                        <div class="item-title">Clear Quartz Cluster</div>
                        <div class="item-price">$200 - $500</div>
                        <div class="item-description">Premium quality clear quartz crystals. Ideal for home decoration and wellness.</div>
                    </div>
                </div>
                <div class="gallery-item">
                    <div class="item-image">💜</div>
                    <div class="item-content">
                        <div class="item-title">Mixed Crystal Set</div>
                        <div class="item-price">$150 - $400</div>
                        <div class="item-description">Curated collection of various crystals. Includes display case.</div>
                    </div>
                </div>
                <div class="gallery-item">
                    <div class="item-image">⭐</div>
                    <div class="item-content">
                        <div class="item-title">Agate Slice Pendant</div>
                        <div class="item-price">$100 - $300</div>
                        <div class="item-description">Beautiful agate slices. Perfect for jewelry and unique gifts.</div>
                    </div>
                </div>
                <div class="gallery-item">
                    <div class="item-image">🔮</div>
                    <div class="item-content">
                        <div class="item-title">Crystal Sphere</div>
                        <div class="item-price">$450 - $900</div>
                        <div class="item-description">Polished crystal spheres. Rare natural formations.</div>
                    </div>
                </div>
                <div class="gallery-item">
                    <div class="item-image">🌟</div>
                    <div class="item-content">
                        <div class="item-title">Designer Display Box</div>
                        <div class="item-price">$500 - $1200</div>
                        <div class="item-description">Luxury packaging for premium collectors. Custom available.</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Owner Section -->
    <section id="owner" class="section">
        <div class="container">
            <h2 class="section-title">Owner Portal</h2>
            
            <div class="owner-container">
                <div class="owner-info">
                    <h3>Business Information</h3>
                    <p>Welcome to Diva Gallery's Owner Portal. Manage your collections, update inventory, and upload new products to showcase your exclusive luxury items.</p>
                    
                    <div class="contact-info">
                        <div class="contact-item">
                            <strong>📍 Location</strong>
                            189D Jumeirah 1, Beach Road<br>
                            Al Attar Bldg., Villa # 8<br>
                            Dubai, U.A.E.
                        </div>
                        <div class="contact-item">
                            <strong>📞 Phone</strong>
                            +971 4 548 7100
                        </div>
                        <div class="contact-item">
                            <strong>📧 Email</strong>
                            divajumeirah@gmail.com
                        </div>
                        <div class="contact-item">
                            <strong>🌐 Website</strong>
                            www.divajumeirah.com
                        </div>
                        <div class="contact-item">
                            <strong>📬 P.O. Box</strong>
                            417902, Dubai, U.A.E
                        </div>
                    </div>
                </div>

                <div>
                    <h3 style="color: var(--gold); margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 2px;">Add New Product</h3>
                    
                    <div class="upload-section">
                        <h4>Upload Product Image</h4>
                        <input type="file" id="productImage" accept="image/*" placeholder="Choose image">
                        <p style="color: rgba(255, 255, 255, 0.5); font-size: 0.9rem;">Recommended: 600x600px or larger</p>
                    </div>

                    <div class="upload-form">
                        <input type="text" id="productName" placeholder="Product Name" required>
                        <input type="text" id="productPrice" placeholder="Price (e.g., $350)">
                        <input type="text" id="productCategory" placeholder="Category" style="grid-column: 1 / -1;">
                        <textarea id="productDesc" placeholder="Product Description" style="grid-column: 1 / -1; height: 120px;" required></textarea>
                        <button class="btn btn-primary" onclick="addProduct()" style="grid-column: 1 / -1; width: 100%;">Add Product</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section">
        <div class="container">
            <h2 class="section-title">Get In Touch</h2>
            <div style="background: rgba(107, 76, 154, 0.1); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 10px; padding: 3rem; text-align: center; margin-top: 3rem;">
                <p style="color: var(--cream); font-size: 1.1rem; line-height: 1.8; margin-bottom: 2rem;">
                    We'd love to hear from you. Reach out with any inquiries about our collections or custom orders.
                </p>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
                    <div>
                        <p style="color: var(--gold); font-weight: bold; margin-bottom: 0.5rem;">📞 Call Us</p>
                        <p style="color: var(--cream);">+971 4 548 7100</p>
                    </div>
                    <div>
                        <p style="color: var(--gold); font-weight: bold; margin-bottom: 0.5rem;">📧 Email</p>
                        <p style="color: var(--cream);">divajumeirah@gmail.com</p>
                    </div>
                    <div>
                        <p style="color: var(--gold); font-weight: bold; margin-bottom: 0.5rem;">🌐 Visit</p>
                        <p style="color: var(--cream);">www.divajumeirah.com</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-links">
                <a href="#buyer">Collections</a>
                <a href="#owner">Owner Portal</a>
                <a href="#contact">Contact</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Terms & Conditions</a>
            </div>
            <p>&copy; 2024 Diva Gallery. All rights reserved. Where Nature Meets Luxury.</p>
        </div>
    </footer>

    <script>
        // Smooth scroll function
        function scrollTo(id) {
            console.log('Scrolling to:', id);
            const section = document.getElementById(id);
            if (section) {
                const offset = 80; // Account for fixed nav
                const sectionTop = section.offsetTop - offset;
                window.scrollTo({
                    top: sectionTop,
                    behavior: 'smooth'
                });
            } else {
                console.log('Section not found:', id);
            }
        }

        // Add product function
        function addProduct() {
            const name = document.getElementById('productName').value;
            const price = document.getElementById('productPrice').value;
            const description = document.getElementById('productDesc').value;
            const imageFile = document.getElementById('productImage').files[0];

            if (!name || !description) {
                alert('Please fill in product name and description');
                return;
            }

            // Create new product element
            const newProduct = document.createElement('div');
            newProduct.className = 'gallery-item';
            
            let imageHTML = '📸';
            if (imageFile) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const imgElement = newProduct.querySelector('.item-image');
                    imgElement.innerHTML = '<img src="' + e.target.result + '" style="width: 100%; height: 100%; object-fit: cover;">';
                };
                reader.readAsDataURL(imageFile);
            }
            
            newProduct.innerHTML = `
                <div class="item-image" style="background: linear-gradient(135deg, #8b5fbf, #6b4c9a); display: flex; align-items: center; justify-content: center;">
                    ${imageHTML}
                </div>
                <div class="item-content">
                    <div class="item-title">${name}</div>
                    <div class="item-price">${price || 'Contact for price'}</div>
                    <div class="item-description">${description}</div>
                </div>
            `;

            document.getElementById('gallery').insertBefore(newProduct, document.getElementById('gallery').firstChild);

            // Reset form
            document.getElementById('productImage').value = '';
            document.getElementById('productName').value = '';
            document.getElementById('productPrice').value = '';
            document.getElementById('productDesc').value = '';

            alert('Product added successfully!');
        }

        // Initialize navigation links
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page loaded');
            
            // Add click handlers to navigation links
            const navLinks = document.querySelectorAll('.nav-menu a');
            navLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (href.startsWith('#')) {
                        e.preventDefault();
                        const id = href.substring(1);
                        scrollTo(id);
                    }
                });
            });

            // Add click handlers to CTA buttons
            const buttons = document.querySelectorAll('.cta-buttons button');
            buttons.forEach(btn => {
                btn.addEventListener('click', function() {
                    console.log('Button clicked');
                });
            });
        });
    </script>
</body>
